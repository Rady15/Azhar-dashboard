# ─── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/compound_db

# ─── JWT Secrets (use long random strings in production) ──
JWT_SECRET_ADMIN=admin_super_secret_change_in_production_min_32_chars
JWT_SECRET_TENANT=tenant_super_secret_change_in_production_min_32_chars
JWT_SECRET_STAFF=staff_super_secret_change_in_production_min_32_chars
JWT_REFRESH_SECRET=refresh_super_secret_change_in_production_min_32_chars

# Token lifetimes
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ─── Email (SMTP) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourcompound.com
SMTP_PASS=your_app_password
EMAIL_FROM="Compound Manager <noreply@yourcompound.com>"

# ─── File Uploads ─────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# ─── Firebase Cloud Messaging (Push Notifications) ────────
# Get from Firebase Console → Project Settings → Service Account
FCM_SERVER_KEY=your_fcm_server_key_here

# ─── App Settings ─────────────────────────────────────────
COMPOUND_NAME=كمباوند النخيل
COMPOUND_ID=1
FRONTEND_URL=http://localhost:8080
OTP_EXPIRES_MINUTES=10
